# 🔐 Environment Variables - NUNCA commitear con valores reales

# ========== BROKERS API KEYS ==========
# Interactive Brokers
IBKR_API_KEY=your_ibkr_api_key_here
IBKR_ACCOUNT=your_ibkr_account_id_here
IBKR_BASE_URL=https://api.interactive-brokers.com

# Alpaca Trading
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://api.alpaca.markets

# ========== DATABASE - SUPABASE ==========
VITE_SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ========== DATABASE - MONGODB ==========
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pwa_inversions?retryWrites=true&w=majority

# ========== ENVIRONMENT ==========
VITE_ENV=development
VITE_API_BASE_URL=http://localhost:3000/api
VITE_APP_NAME=PWA Inversiones DRFIC

# ========== LOGGING ==========
VITE_LOG_LEVEL=debug
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# ========== FEATURE FLAGS ==========
VITE_FEATURE_PAPER_TRADING=true
VITE_FEATURE_LIVE_TRADING=false
VITE_FEATURE_ALERTS=true
VITE_FEATURE_NOTIFICATIONS=true
